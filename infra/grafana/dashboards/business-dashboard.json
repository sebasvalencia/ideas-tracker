{
  "title": "Ideas API - Business Dashboard",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "title": "Ideas Created (24h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(ideas_created_total[24h]))"
        }
      ]
    },
    {
      "title": "Ideas Completed (24h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(ideas_completed_total[24h]))"
        }
      ]
    },
    {
      "title": "Average Rating",
      "type": "stat",
      "targets": [
        {
          "expr": "ideas_rating_average"
        }
      ]
    },
    {
      "title": "Mean Cycle Time (hours)",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(idea_cycle_time_seconds_sum[24h]) / rate(idea_cycle_time_seconds_count[24h]) / 3600"
        }
      ]
    }
  ]
}
