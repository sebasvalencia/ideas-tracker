# ------------------------------
# Docker Compose environment
# Copy this file to .env and adjust values.
# ------------------------------

# Postgres
POSTGRES_DB=ideas_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@ideas.com
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin

# Backend
APP_ENV=development
APP_PORT=8000
JWT_SECRET_KEY=change_me_jwt_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_MINUTES=10080
AUTH_RATE_LIMIT_LOGIN=5/minute
OTEL_ENABLED=true
OTEL_SERVICE_NAME=ideas-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
METRICS_ENABLED=true

# Internal Docker network host for postgres is "postgres"
DATABASE_URL=postgresql+psycopg://postgres:change_me_postgres@postgres:5432/ideas_tracker

# Frontend
BACKEND_API_URL=http://backend:8000
BACKEND_API_V1_BASE_URL=http://backend:8000/api/v1
NODE_ENV=production
